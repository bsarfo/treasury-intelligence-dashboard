# =====================================================================
# Streamlit Cloud secrets template
# =====================================================================
# When deploying to Streamlit Cloud:
#   1. DO NOT commit the actual secrets.toml — it's in .gitignore
#   2. In your Streamlit Cloud app dashboard, click "Settings" → "Secrets"
#   3. Paste the contents below with your real values
#
# For LOCAL development, use the .env file instead (in project root).
# =====================================================================

FRED_API_KEY = "your_fred_key_here"
ANTHROPIC_API_KEY = "your_anthropic_key_here"
SEC_USER_AGENT = "Your Name your.email@example.com"
